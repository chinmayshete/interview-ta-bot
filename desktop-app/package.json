{
  "name": "interview-support-agent",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Interview Support Agent — Desktop Application",
  "author": "Chinmay Shete",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:start": "electron .",
    "desktop": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:start\"",
    "build:electron": "vite build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.chinmay.interview-support-agent",
    "productName": "Interview Support Agent",
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python_backend/**/*",
      "!python_backend/venv/**/*",
      "!python_backend/__pycache__/**/*"
    ],
    "extraResources": [
      {
        "from": "python_backend",
        "to": "python_backend",
        "filter": ["**/*", "!venv/**", "!__pycache__/**"]
      }
    ]
  }
}
